# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gamebazaar
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# ─── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Admin UPI (for real UPI QR generation) ───────────────────
ADMIN_UPI_ID=yourname@upi
ADMIN_UPI_NAME=GameBazaar

# ─── Admin Contact ────────────────────────────────────────────
ADMIN_WHATSAPP_NUMBER=91XXXXXXXXXX

# ─── Gmail (App Password — NOT your Gmail password) ───────────
# Step 1: Enable 2FA on Gmail
# Step 2: myaccount.google.com/apppasswords → create App Password
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Frontend URL (for CORS) ──────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── File Upload ──────────────────────────────────────────────
UPLOAD_DIR=uploads/games
MAX_FILE_SIZE=5242880

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
