# ─── OS & Editor ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/
.idea/
*.iml

# ─── Node / npm ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json

# ─── Environment files (NEVER commit secrets) ────────────────
.env
.env.local
.env.development
.env.production
.env.staging
backend/.env
frontend/.env
frontend/.env.local

# ─── Build outputs ───────────────────────────────────────────
dist/
build/
.next/
out/

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log

# ─── Uploaded game files / user content ──────────────────────
# Keep the uploads folder structure but ignore actual files
backend/uploads/games/*
!backend/uploads/games/.gitkeep

# ─── Test coverage ───────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ────────────────────────────────────────────────────
.cache/
tmp/
temp/
